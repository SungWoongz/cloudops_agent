# CloudOps v2 Environment Variables
#
# 1) Copy this file to `.env.local` (git-ignored).
# 2) Fill in the values for your account / environment.
# 3) The SessionStart hook in `.claude/settings.json` exports these into the
#    Claude Code session automatically.
#
#    cp env.sample .env.local
#    $EDITOR .env.local

# -- AWS / CodeArtifact --
AWS_ACCOUNT_ID=123456789012
AWS_PROFILE=sandbox
CODEARTIFACT_DOMAIN=mzc-cloudops
CODEARTIFACT_REPO=cloudops-pypi
CODEARTIFACT_REGION=ap-northeast-2
ECR_REGION=ap-northeast-2

# -- MongoDB (local dev) --
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=cloudops
MONGO_PASSWORD=changeme
MONGO_DB=cloudops
MONGO_URI=mongodb://cloudops:changeme@localhost:27017/cloudops

# -- PostgreSQL (local dev) --
PG_HOST=localhost
PG_PORT=5432
PG_USER=cloudops
PG_PASSWORD=changeme
PG_DB=cloudops
DATABASE_URL=postgresql://cloudops:changeme@localhost:5432/cloudops
